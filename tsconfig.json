{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts", // if not astro is not defined
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "types": ["node"],
    "jsx": "react-jsx", // no to write import React from 'react' in every file
    "jsxImportSource": "preact", // jsx runtime is from preact
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "verbatimModuleSyntax": true, // automatic type inference for properties
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@styles/*": ["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
    }

  }
}