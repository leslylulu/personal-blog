---
import BaseLayout from "@layouts/BaseLayout.astro";

interface Frontmatter {
  title: string;
  pubDate: Date;
  description: string;
  author: string;
  image: {
    url: string;
    alt: string;
  };
  tags: string[];
}

interface Props {
  frontmatter: Frontmatter;
  minutesToRead?: number;
}

const { frontmatter, minutesToRead } = Astro.props;
---

<BaseLayout pageTitle={`${frontmatter.title} — Lulu Zhang`}>
  <article class="w-full">
    <!-- Article hero -->
    <div class="relative w-full overflow-hidden border-b border-black/8 dark:border-white/8">
      <div
        class="absolute inset-0 bg-[linear-gradient(rgba(17,0,49,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(17,0,49,0.04)_1px,transparent_1px)] bg-[size:40px_40px] dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)]"
      >
      </div>
      <div class="relative z-10 mx-auto max-w-3xl px-8 pt-28 pb-16">
        <!-- Tags -->
        <div class="mb-6 flex flex-wrap gap-2">
          {
            frontmatter.tags.map((tag: string) => (
              <a
                href={`/tags/${tag}`}
                class="group text-navy/50 border border-black/10 px-4 py-1.5 text-xs tracking-wider uppercase transition-all duration-300 hover:border-black hover:bg-black hover:text-white dark:border-white/10 dark:text-white/40 dark:hover:border-white dark:hover:bg-white dark:hover:text-black"
              >
                # {tag}
              </a>
            ))
          }
        </div>

        <!-- Title -->
        <h1 class="text-4xl leading-tight font-black tracking-tight text-gray-900 md:text-6xl dark:text-white">
          {frontmatter.title}
        </h1>

        <p class="text-navy/60 mt-5 text-lg dark:text-white/50">{frontmatter.description}</p>

        <!-- Meta row -->
        <div class="text-navy/40 mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm dark:text-white/30">
          <span class="font-medium">{frontmatter.author}</span>
          <span class="h-1 w-1 rounded-full bg-current"></span>
          <time>
            {
              new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          {
            minutesToRead !== undefined && (
              <>
                <span class="h-1 w-1 rounded-full bg-current" />
                <span class="flex items-center gap-1">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {minutesToRead} min read
                </span>
              </>
            )
          }
        </div>
      </div>
    </div>

    <!-- Hero image -->
    {
      frontmatter.image?.url && (
        <div class="mx-auto max-w-3xl px-8 pt-10">
          <img src={frontmatter.image.url} alt={frontmatter.image.alt} class="w-full object-cover" style="max-height: 420px;" />
        </div>
      )
    }

    <!-- Prose content -->
    <div class="prose-content mx-auto max-w-3xl px-8 py-12 pb-28">
      <slot />
    </div>
  </article>
</BaseLayout>
