---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";

interface Props {
  pageTitle?: string;
}
const { pageTitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.bunny.net/css?family=metropolis:400,500,700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-cream dark:bg-navy flex min-h-screen flex-col">
    <Header />
    <main class="mx-auto flex w-full grow flex-col items-center p-0">
      {pageTitle && <h1>{pageTitle}</h1>}
      <slot />
    </main>
    <Footer />
    <script>
      import "@scripts/menu.ts";
    </script>
  </body>
</html>
