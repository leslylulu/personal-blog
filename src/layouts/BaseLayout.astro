---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

interface Props {
  pageTitle?: string;
}
const { pageTitle } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.bunny.net/css?family=metropolis:400,500,700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-cream dark:bg-navy">
    <Header />
    <main class="grow w-full max-w-5xl mx-auto px-12 py-12">
      {pageTitle && <h1>{pageTitle}</h1>}
      <slot />
    </main>
    <Footer />
    <script>
      import "@scripts/menu.ts";
    </script>
  </body>
</html>