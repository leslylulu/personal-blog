---
interface Props {
  title: string;
  url: string;
  description?: string;
  pubDate?: Date | string;
  minutesToRead?: number;
  image?: { url: string; alt: string } | null;
  tags?: string[];
}

const { title, url, description, pubDate, minutesToRead, image, tags } = Astro.props;

const dateStr = pubDate
  ? new Date(pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<li class="list-none border-b border-black/6 last:border-none dark:border-white/6">
  <a href={url} class="group flex items-center gap-5 py-8 transition-colors duration-200 sm:gap-7">
    <!-- Thumbnail -->
    <div class="h-20 w-28 shrink-0 overflow-hidden sm:h-28 sm:w-40">
      {
        image?.url ? (
          <img src={image.url} alt={image.alt || title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-purple-100 to-blue-100 dark:from-purple-900/20 dark:to-blue-900/20">
            <span class="text-3xl font-black text-purple-300 select-none dark:text-purple-700">{title[0]?.toUpperCase()}</span>
          </div>
        )
      }
    </div>

    <!-- Content -->
    <div class="flex min-w-0 flex-1 flex-col justify-between py-0.5 sm:py-1">
      <div>
        <h3 class="text-base leading-snug font-bold text-gray-900 transition-colors duration-200 group-hover:text-purple-700 sm:text-lg dark:text-white dark:group-hover:text-cyan-300">
          {title}
        </h3>
        {description && <p class="text-navy/55 mt-2 line-clamp-2 text-sm leading-relaxed dark:text-white/45">{description}</p>}
      </div>

      <!-- Tags + meta -->
      <div class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-xs">
        {tags?.slice(0, 3).map((tag) => <span class="text-navy/45 border border-black/10 px-2.5 py-1 font-medium tracking-wider uppercase dark:border-white/10 dark:text-white/35">{tag}</span>)}
        {(tags?.length ?? 0) > 0 && (dateStr || minutesToRead !== undefined) && <span class="bg-navy/20 mx-0.5 inline-block h-1 w-1 rounded-full dark:bg-white/20" />}
        {dateStr && <time class="text-navy/40 tracking-wide dark:text-white/30">{dateStr}</time>}
        {
          minutesToRead !== undefined && (
            <>
              {dateStr && <span class="text-navy/25 dark:text-white/20">·</span>}
              <span class="text-navy/40 flex items-center gap-1 dark:text-white/30">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
                {minutesToRead} min read
              </span>
            </>
          )
        }
      </div>
    </div>

    <!-- Arrow -->
    <div class="text-navy/20 hidden self-center transition-all duration-300 group-hover:translate-x-1 group-hover:text-purple-500 sm:flex dark:text-white/20 dark:group-hover:text-cyan-400">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </a>
</li>
