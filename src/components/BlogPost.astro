---
interface Props {
  title: string;
  url: string;
  description?: string;
  pubDate?: Date;
  minutesToRead?: number;
}
const { title, url, description, pubDate, minutesToRead } = Astro.props;
---

<li class="list-none">
  <a
    href={url}
    class="group relative flex h-full flex-col overflow-hidden border border-black/8 bg-white/60 p-8 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-black/20 hover:shadow-lg dark:border-white/8 dark:bg-white/3 dark:hover:border-white/20"
  >
    <div
      class="absolute bottom-0 left-0 h-px w-0 bg-linear-to-r from-purple-500 to-blue-500 transition-all duration-500 group-hover:w-full dark:from-cyan-300 dark:to-blue-500"
    >
    </div>

    <!-- Date + reading time -->
    <div class="mb-4 flex items-center gap-3 text-xs text-navy/40 uppercase dark:text-white/30">
      {
        pubDate && (
          <span class="tracking-[0.2em]">
            {new Date(pubDate).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </span>
        )
      }
      {
        minutesToRead !== undefined && (
          <>
            {pubDate && <span class="h-1 w-1 rounded-full bg-current" />}
            <span class="flex items-center gap-1 tracking-[0.15em]">
              <svg
                width="11"
                height="11"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              {minutesToRead} min read
            </span>
          </>
        )
      }
    </div>

    <h3
      class="text-xl font-bold text-gray-900 transition-colors group-hover:text-purple-700 dark:text-white dark:group-hover:text-cyan-300"
    >
      {title}
    </h3>

    {
      description && (
        <p class="mt-3 flex-1 text-sm leading-relaxed text-navy/60 dark:text-white/50">
          {description}
        </p>
      )
    }

    <div class="mt-6 flex items-center gap-1 text-xs font-medium text-navy/40 dark:text-white/30">
      Read more
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform duration-300 group-hover:translate-x-1"
        ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
      >
    </div>
  </a>
</li>
