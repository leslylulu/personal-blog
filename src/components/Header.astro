---
import Navigation from './Navigation.astro';
import Menu from './Menu.astro';
import ThemeIcon from './ThemeIcon.astro';
---
<header>
  <nav>
    <Navigation />
		<div>
			<Menu/>
			<ThemeIcon/>
		</div>
  </nav>
</header>

<style>
	nav{
		display: flex;
		align-items: center;
		flex-direction: row;
		gap: 3rem;
	}
	div{
		display: flex;
		justify-content: space-between;
	}
</style>