---
import Logo from "@components/Logo.astro";
---

<footer class="mt-auto w-full bg-[#0a0a0a]">
  <div class="mx-auto max-w-5xl px-12 pt-16 pb-8">
    <div class="mb-16 grid grid-cols-1 gap-12 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <div class="mb-5">
          <Logo class="text-white" />
        </div>
        <p class="mb-6 max-w-sm text-sm leading-relaxed text-[#999]">A personal blog and creative lab exploring modern web development through Astro, CMS integration, and UI design.</p>
        <div class="flex gap-3">
          <a href="https://github.com/leslylulu/astro-study" target="_blank" aria-label="GitHub" class="flex h-9 w-9 items-center justify-center rounded-full border border-[#333] text-[#999] transition hover:border-[#555] hover:text-white">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <p class="mb-5 text-[11px] font-medium tracking-widest text-white uppercase">Pages</p>
        <ul class="flex flex-col gap-3">
          <li><a href="/about" class="text-sm text-[#999] transition hover:text-white">About</a></li>
          <li><a href="/blog" class="text-sm text-[#999] transition hover:text-white">Blog</a></li>
          <li><a href="/tags" class="text-sm text-[#999] transition hover:text-white">Tags</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-5 text-[11px] font-medium tracking-widest text-white uppercase">Built with</p>
        <ul class="flex flex-col gap-3">
          <li><a href="https://astro.build" target="_blank" class="text-sm text-[#999] transition hover:text-white">Astro</a></li>
          <li><a href="https://tailwindcss.com" target="_blank" class="text-sm text-[#999] transition hover:text-white">Tailwind CSS</a></li>
          <li><a href="https://www.typescriptlang.org" target="_blank" class="text-sm text-[#999] transition hover:text-white">TypeScript</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-center justify-between gap-2 border-t border-[#222] pt-6 md:flex-row">
      <p class="text-xs text-[#555]">© 2025 Lulu Zhang. All rights reserved.</p>
      <p class="text-xs text-[#555]">
        Designed & developed by
        <a href="https://profile.catlulu.net/" target="_blank" class="text-[#999] transition hover:text-white">Lulu Zhang</a>
      </p>
    </div>
  </div>
</footer>
