---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogPost from "@components/BlogPost.astro";
import { getReadingTime } from "@utils/readingTime";

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const sortedPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .map((post) => {
    // Sanity body is Portable Text (array of blocks), not a markdown string.
    // Extract plain text from each block's children spans for reading time.
    const plainText = (post.data.body ?? [])
      .filter((block: { _type: string }) => block._type === "block")
      .flatMap((block: { children: { text: string }[] }) => block.children.map((span) => span.text))
      .join(" ");
    return { post, minutesToRead: getReadingTime(plainText) };
  });
---

<BaseLayout pageTitle="Blog — Lulu Zhang">
  <section class="relative w-full overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(17,0,49,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(17,0,49,0.04)_1px,transparent_1px)] bg-[size:40px_40px] dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)]"
    >
    </div>
    <div class="relative z-10 mx-auto max-w-6xl px-8 pt-28 pb-20">
      <p class="mb-4 text-xs tracking-[0.35em] text-navy/40 uppercase dark:text-white/30">
        Writing
      </p>
      <h1
        class="text-6xl font-black leading-none tracking-tight text-gray-900 md:text-8xl dark:text-white"
      >
        Blog
      </h1>
      <p class="mt-6 max-xl text-lg text-navy/60 dark:text-white/50">
        Thoughts, learnings, and notes from my frontend journey.
      </p>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-8 py-16">
    <ul class="grid gap-6 md:grid-cols-2">
      {
        sortedPosts.map(({ post, minutesToRead }) => (
          <BlogPost
            url={`/posts/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            minutesToRead={minutesToRead}
          />
        ))
      }
    </ul>
  </section>
</BaseLayout>
