---
import '@styles/global.css';
const pageTitle = "Page Not Found";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>

  <body class="w-full min-h-screen flex items-center justify-center p-0 text-gray-200">
    <main class="text-center max-w-md p-10 border border-white/10 rounded-2xl bg-gray-900/90 backdrop-blur-lg shadow-2xl">
      <h1 class="text-8xl m-0 tracking-tight bg-linear-to-r from-indigo-600 to-cyan-200 bg-clip-text text-transparent leading-tight">404</h1>
      <h2 class="mt-3 text-2xl font-semibold">This page drifted away</h2>

      <p class="mt-2.5 text-gray-400 leading-relaxed text-sm">
        The route you tried to access doesn't exist anymore, or never existed.
        Check the URL or head back to a safe place.
      </p>

      <div class="mt-7 flex gap-3 justify-center flex-wrap">
        <a 
          class="no-underline px-4 py-2.5 rounded-lg text-sm transition-all border border-white/10 text-gray-200 bg-white/5 hover:bg-white/10 hover:-translate-y-0.5" 
          href="/blog"
        >
          Read Blog
        </a>
        <a 
          class="no-underline px-4 py-2.5 rounded-lg text-sm transition-all border-none text-white bg-indigo-600 hover:bg-indigo-700 hover:-translate-y-0.5" 
          href="/"
        >
          Go Home
        </a>
      </div>

      <div class="mt-6 text-xs text-gray-500">
        Tip: double-check the URL or use navigation
      </div>
    </main>
  </body>
</html>
