---
import "@styles/global.css";
const pageTitle = "Page Not Found";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>

  <body class="flex min-h-screen w-full items-center justify-center p-0 text-gray-200">
    <main class="max-w-md rounded-2xl border border-white/10 bg-gray-900/90 p-10 text-center shadow-2xl backdrop-blur-lg">
      <h1 class="m-0 bg-linear-to-r from-indigo-600 to-cyan-200 bg-clip-text text-8xl leading-tight tracking-tight text-transparent">404</h1>
      <h2 class="mt-3 text-2xl font-semibold">This page drifted away</h2>

      <p class="mt-2.5 text-sm leading-relaxed text-gray-400">The route you tried to access doesn't exist anymore, or never existed. Check the URL or head back to a safe place.</p>

      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a class="rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-gray-200 no-underline transition-all hover:-translate-y-0.5 hover:bg-white/10" href="/blog"> Read Blog </a>
        <a class="rounded-lg border-none bg-indigo-600 px-4 py-2.5 text-sm text-white no-underline transition-all hover:-translate-y-0.5 hover:bg-indigo-700" href="/"> Go Home </a>
      </div>

      <div class="mt-6 text-xs text-gray-500">Tip: double-check the URL or use navigation</div>
    </main>
  </body>
</html>
