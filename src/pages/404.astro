---
const pageTitle = "Page Not Found";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>

    <style>
      :root {
        --bg: #0b0f19;
        --card: #111827;
        --text: #e5e7eb;
        --muted: #9ca3af;
        --primary: #6366f1;
        --border: rgba(255, 255, 255, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: radial-gradient(circle at top, #111827, #0b0f19);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      main {
        text-align: center;
        max-width: 520px;
        padding: 40px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(10px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
      }

      h1 {
        font-size: 88px;
        margin: 0;
        letter-spacing: -2px;
        line-height: 1;
        background: linear-gradient(135deg, #6366f1, #22d3ee);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      h2 {
        margin-top: 12px;
        font-size: 22px;
        font-weight: 600;
      }

      p {
        margin-top: 10px;
        color: var(--muted);
        line-height: 1.6;
        font-size: 14px;
      }

      .actions {
        margin-top: 28px;
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
      }

      a {
        text-decoration: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 14px;
        transition: all 0.2s ease;
        border: 1px solid var(--border);
        color: var(--text);
        background: rgba(255, 255, 255, 0.03);
      }

      a.primary {
        background: var(--primary);
        border-color: transparent;
        color: white;
      }

      a:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.2);
      }

      a.primary:hover {
        background: #4f46e5;
      }

      .hint {
        margin-top: 24px;
        font-size: 12px;
        color: #6b7280;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>404</h1>

      <h2>This page drifted away</h2>

      <p>
        The route you tried to access doesn’t exist anymore, or never existed.
        Check the URL or head back to a safe place.
      </p>

      <div class="actions">
        <a class="primary" href="/">Go Home</a>
        <a href="/blog">Read Blog</a>
      </div>

      <div class="hint">
        Tip: double-check the URL or use navigation
      </div>
    </main>
  </body>
</html>