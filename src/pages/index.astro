---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto max-w-4xl px-0 py-24">
    <p class="text-sm tracking-widest text-gray-500 uppercase">May · Learning Journey</p>

    <h1 class="mt-4 text-5xl leading-tight font-bold">
      Started building this project on
      <span class="bg-linear-to-r from-purple-500 to-blue-500 bg-clip-text text-transparent"> May 22 </span>
    </h1>

    <p class="mt-6 max-w-2xl text-lg font-normal tracking-widest text-gray-600">This project is part of my ongoing frontend growth journey. I’m iterating step by step, learning Astro, refining UI structure, and building a scalable CMS-driven blog system.</p>

    <h2 class="mt-24 mb-6 text-3xl font-bold">What I will Do</h2>

    <div class="grid gap-6 md:grid-cols-3">
      <div class="border p-6 transition hover:shadow-xl">
        <h3 class="text-xl font-semibold">Frontend Engineering</h3>
        <p class="mt-2 text-sm text-gray-600">React / Astro / TypeScript architecture & performance optimization.</p>
      </div>

      <div class="border p-6 transition hover:shadow-xl">
        <h3 class="text-xl font-semibold">CMS Systems</h3>
        <p class="mt-2 text-sm text-gray-600">Strapi / headless CMS / content-driven websites.</p>
      </div>

      <div class="border p-6 transition hover:shadow-xl">
        <h3 class="text-xl font-semibold">UI Design</h3>
        <p class="mt-2 text-sm text-gray-600">Modern interface design with Tailwind + motion effects.</p>
      </div>
    </div>

    <h2 class="mt-24 mb-10 text-3xl font-bold">Tech Stack</h2>

    <div class="flex flex-wrap gap-3">
      {["React", "Astro", "TypeScript", "Tailwind", "Preline", "Strapi"].map((t) => <span class="text-navy border px-4 py-2 transition hover:bg-black hover:text-white dark:text-gray-400"># {t}</span>)}
    </div>
  </section>

  <section class="from-navy w-full bg-linear-to-r to-black px-0 py-24 text-center text-white">
    <h2 class="text-3xl font-bold">Let’s build something modern</h2>
    <p class="mt-4 text-white/70">Open to frontend / UI / CMS roles</p>

    <button class="mt-8 rounded-full bg-white px-6 py-3 text-black transition hover:scale-105"> Contact Me </button>
  </section>
</BaseLayout>
